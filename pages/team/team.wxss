/* pages/team/team.wxss - 组队页面样式 */

/* 组队主题色 */
:root {
  --team-color: #722ed1; /* 紫色主题 */
  --team-color-light: #f9f0ff;
  --team-color-dark: #531dab;
}

.container {
  padding-bottom: 120rpx;
  min-height: 100vh;
}

/* 加载状态 */
.loading {
  display: flex;
  justify-content: center;
  align-items: center;
  height: 200rpx;
}

.loading-text {
  font-size: 28rpx;
  color: #666666;
}

/* 没有团队的情况 */
.no-team .title {
  font-size: 36rpx;
  font-weight: bold;
  color: var(--team-color);
  margin-bottom: 16rpx;
  text-align: center;
}

.no-team .description {
  font-size: 28rpx;
  color: #666666;
  text-align: center;
  margin-bottom: 48rpx;
  line-height: 1.6;
}

.team-illustration {
  text-align: center;
  margin: 48rpx 0;
}

.illustration-icon {
  font-size: 120rpx;
  margin-bottom: 16rpx;
}

.illustration-text {
  font-size: 28rpx;
  color: #666666;
}

.action-buttons {
  display: flex;
  justify-content: center;
  gap: 32rpx;
  margin: 48rpx 0;
}

.btn {
  border-radius: 48rpx;
  padding: 24rpx 48rpx;
  font-size: 32rpx;
  font-weight: 500;
  text-align: center;
  transition: all 0.3s;
  border: none;
  display: inline-block;
  margin: 16rpx;
}

.btn-hover:active {
  opacity: 0.8;
  transform: scale(0.98);
}

.btn-primary {
  background: linear-gradient(135deg, var(--team-color), var(--team-color-dark));
  color: #ffffff;
  box-shadow: 0 8rpx 24rpx rgba(114, 46, 209, 0.3);
}

.btn-secondary {
  background-color: #ffffff;
  color: var(--team-color);
  border: 2rpx solid var(--team-color);
}

.btn-warning {
  background-color: #fffbe6;
  color: #faad14;
  border: 2rpx solid #faad14;
}

.btn-warning:active {
  background-color: #faad14;
  color: #ffffff;
}

.team-tips {
  margin-top: 48rpx;
  border-top: 2rpx solid #f0f0f0;
  padding-top: 32rpx;
}

.tip-item {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
}

.tip-icon {
  font-size: 24rpx;
  margin-right: 16rpx;
  color: var(--team-color);
}

.tip-text {
  font-size: 26rpx;
  color: #666666;
}

/* 加入团队表单 */
.join-form .title {
  font-size: 36rpx;
  font-weight: bold;
  color: var(--team-color);
  margin-bottom: 16rpx;
  text-align: center;
}

.join-form .description {
  font-size: 28rpx;
  color: #666666;
  text-align: center;
  margin-bottom: 48rpx;
}

.form-group {
  margin: 48rpx 0;
}

.input {
  border: 2rpx solid #e8e8e8;
  border-radius: 12rpx;
  padding: 24rpx;
  font-size: 32rpx;
  background-color: #ffffff;
  text-align: center;
  letter-spacing: 8rpx;
}

.input:focus {
  border-color: var(--team-color);
  outline: none;
}

.input-placeholder {
  color: #cccccc;
}

.input-hint {
  font-size: 24rpx;
  color: #999999;
  text-align: center;
  margin-top: 16rpx;
}

.form-buttons {
  display: flex;
  justify-content: center;
  gap: 32rpx;
  margin-top: 48rpx;
}

/* 有团队的情况 */
.team-status-card {
  margin-top: 0;
}

.team-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 32rpx;
  border-bottom: 2rpx solid #f0f0f0;
  padding-bottom: 24rpx;
}

.team-title {
  font-size: 32rpx;
  font-weight: bold;
  color: var(--team-color);
  display: flex;
  align-items: center;
}

.team-icon {
  font-size: 36rpx;
  margin-right: 12rpx;
}

.team-actions {
  display: flex;
  gap: 16rpx;
}

.btn-icon {
  background: none;
  border: none;
  padding: 8rpx 16rpx;
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 24rpx;
  color: var(--team-color);
}

.btn-icon:active {
  opacity: 0.7;
}

.btn-icon .icon {
  font-size: 28rpx;
}

.btn-text {
  font-size: 24rpx;
}

.team-info {
  margin-bottom: 32rpx;
}

.info-item {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
  font-size: 28rpx;
}

.info-label {
  color: #666666;
  min-width: 140rpx;
}

.info-value {
  color: #333333;
  font-weight: 500;
}

.team-code {
  font-family: monospace;
  font-size: 32rpx;
  letter-spacing: 2rpx;
  color: var(--team-color);
  font-weight: bold;
}

.status-badge {
  display: inline-block;
  padding: 8rpx 16rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
  font-weight: 500;
}

.status-badge.active {
  background-color: #e6f7e6;
  color: #52c41a;
}

.status-badge.waiting {
  background-color: #fffbe6;
  color: #faad14;
}

/* 今日打卡状态 */
.today-punch-section {
  margin: 32rpx 0;
  padding: 24rpx;
  background-color: #fafafa;
  border-radius: 12rpx;
}

.section-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 24rpx;
  text-align: center;
}

.punch-status-grid {
  display: flex;
  justify-content: space-around;
  gap: 32rpx;
}

.punch-status-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
}

.punch-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  font-weight: bold;
  color: #ffffff;
  margin-bottom: 16rpx;
}

.punch-avatar.self {
  background: linear-gradient(135deg, var(--team-color), var(--team-color-dark));
}

.punch-avatar.partner {
  background: linear-gradient(135deg, #52c41a, #87d068);
}

.punch-status {
  text-align: center;
}

.punched {
  display: block;
  font-size: 26rpx;
  color: #52c41a;
  margin-bottom: 8rpx;
}

.not-punched {
  display: block;
  font-size: 26rpx;
  color: #faad14;
  margin-bottom: 8rpx;
}

.punch-time {
  display: block;
  font-size: 24rpx;
  color: #999999;
}

/* 标签页切换 */
.tabs {
  display: flex;
  border-bottom: 2rpx solid #f0f0f0;
  margin: 32rpx 0;
}

.tab {
  flex: 1;
  text-align: center;
  padding: 24rpx 0;
  font-size: 28rpx;
  color: #666666;
  position: relative;
}

.tab.active {
  color: var(--team-color);
  font-weight: bold;
}

.tab.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 60%;
  height: 4rpx;
  background-color: var(--team-color);
  border-radius: 2rpx;
}

/* 团队状态标签页 */
.team-stats {
  display: flex;
  justify-content: space-around;
  margin: 32rpx 0 48rpx;
}

.stat-item {
  text-align: center;
}

.stat-value {
  display: block;
  font-size: 48rpx;
  font-weight: bold;
  color: var(--team-color);
  margin-bottom: 8rpx;
}

.stat-label {
  display: block;
  font-size: 24rpx;
  color: #666666;
}

.team-actions-full {
  text-align: center;
  margin-top: 48rpx;
}

/* 打卡记录标签页 */
.empty-records {
  text-align: center;
  padding: 64rpx 0;
}

.empty-icon {
  font-size: 80rpx;
  display: block;
  margin-bottom: 24rpx;
  opacity: 0.5;
}

.empty-text {
  font-size: 28rpx;
  color: #999999;
}

.punch-records {
  max-height: 600rpx;
  overflow-y: auto;
}

.record-item {
  padding: 24rpx;
  border-bottom: 2rpx solid #f0f0f0;
}

.record-item:last-child {
  border-bottom: none;
}

.record-date {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.date {
  font-size: 28rpx;
  font-weight: bold;
  color: #333333;
}

.weekday {
  font-size: 24rpx;
  color: #999999;
}

.record-details {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.record-user {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.user-avatar {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 20rpx;
  font-weight: bold;
  color: #ffffff;
}

.user-avatar.self {
  background-color: var(--team-color);
}

.user-avatar.partner {
  background-color: #52c41a;
}

.user-action {
  font-size: 26rpx;
  color: #666666;
}

.user-part {
  font-size: 26rpx;
  font-weight: bold;
  color: var(--team-color);
}

.record-time {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.time-icon {
  font-size: 24rpx;
  color: #999999;
}

.time {
  font-size: 26rpx;
  color: #666666;
}

/* 响应式调整 */
@media (max-width: 600rpx) {
  .action-buttons,
  .form-buttons {
    flex-direction: column;
    gap: 24rpx;
  }

  .btn {
    width: 100%;
    margin: 0;
  }

  .team-actions {
    flex-direction: column;
    gap: 8rpx;
  }

  .punch-status-grid {
    flex-direction: column;
    gap: 24rpx;
  }

  .team-stats {
    flex-direction: column;
    gap: 32rpx;
  }
}