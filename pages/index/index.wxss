/* pages/index/index.wxss - 首页样式 */

.container {
  padding-bottom: 120rpx;
}

/* 顶部状态栏 */
.status-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx 32rpx 16rpx;
  background-color: #ffffff;
}

.date {
  font-size: 28rpx;
  color: #666666;
}

.plan-name {
  font-size: 24rpx;
  color: #52c41a;
  background-color: #e6f7e6;
  padding: 8rpx 16rpx;
  border-radius: 20rpx;
}

/* 训练卡片 */
.training-card {
  text-align: center;
  margin-top: 0;
}

.training-card .label {
  font-size: 28rpx;
  color: #666666;
  display: block;
  margin-bottom: 16rpx;
}

.training-card .today-part {
  font-size: 80rpx;
  font-weight: bold;
  color: #52c41a;
  display: block;
  margin: 24rpx 0;
  line-height: 1.2;
}

.training-card .tip {
  font-size: 24rpx;
  color: #999999;
  display: block;
}

/* 打卡按钮区域 */
.punch-section {
  text-align: center;
  margin: 48rpx 32rpx;
}

.btn-punch {
  background: linear-gradient(135deg, #87d068, #52c41a);
  color: #ffffff;
  font-size: 40rpx;
  font-weight: bold;
  padding: 32rpx 64rpx;
  border-radius: 80rpx;
  box-shadow: 0 8rpx 24rpx rgba(82, 196, 26, 0.3);
  border: none;
  width: 80%;
  max-width: 600rpx;
}

.btn-punch.punch-disabled {
  background: #cccccc;
  box-shadow: none;
  opacity: 0.7;
}

.punch-tip {
  display: block;
  font-size: 24rpx;
  color: #999999;
  margin-top: 16rpx;
}

/* 明日训练卡片 */
.tomorrow-card {
  text-align: center;
  margin-top: 24rpx;
}

.tomorrow-card .label {
  font-size: 28rpx;
  color: #666666;
  display: block;
  margin-bottom: 16rpx;
}

.tomorrow-card .tomorrow-part {
  font-size: 60rpx;
  font-weight: bold;
  color: #1890ff;
  display: block;
  margin: 16rpx 0;
}

.tomorrow-card .tip {
  font-size: 24rpx;
  color: #999999;
  display: block;
}

/* 计划卡片 */
.plan-card {
  margin-top: 32rpx;
}

.plan-card .label {
  font-size: 32rpx;
  font-weight: bold;
  color: #333333;
}

.change-plan {
  font-size: 26rpx;
  color: #52c41a;
  background-color: #e6f7e6;
  padding: 14rpx 28rpx;
  border-radius: 32rpx;
  border: 2rpx solid #52c41a;
  text-decoration: none;
  font-weight: 600;
  display: inline-block;
  transition: all 0.2s;
  box-shadow: 0 4rpx 12rpx rgba(82, 196, 26, 0.15);
}

.change-plan:active {
  background-color: #52c41a;
  color: #ffffff;
  transform: scale(0.96);
  box-shadow: 0 2rpx 8rpx rgba(82, 196, 26, 0.25);
}

.plan-desc {
  display: block;
  font-size: 28rpx;
  color: #666666;
  margin: 16rpx 0 24rpx;
}

.progress {
  margin-top: 24rpx;
}

.progress-text {
  font-size: 24rpx;
  color: #666666;
  display: block;
  margin-bottom: 12rpx;
}

.progress-percent {
  display: block;
  text-align: right;
  font-size: 24rpx;
  color: #52c41a;
  margin-top: 8rpx;
}

/* 睡眠卡片 */
.sleep-card {
  margin-top: 32rpx;
  padding: 24rpx;
}

.sleep-link {
  display: block;
  text-decoration: none;
  cursor: pointer;
  transition: all 0.2s;
}

.sleep-link:active {
  opacity: 0.8;
  transform: scale(0.99);
}

.sleep-card .label {
  font-size: 32rpx;
  font-weight: bold;
  color: #1890ff;
  display: block;
}

.sleep-tip {
  display: block;
  font-size: 24rpx;
  color: #999999;
  margin-top: 8rpx;
}

.sleep-card .icon {
  font-size: 36rpx;
  color: #1890ff;
  font-weight: bold;
}


/* 底部提示 */
.footer-tip {
  text-align: center;
  font-size: 24rpx;
  color: #999999;
  margin-top: 48rpx;
  padding: 0 32rpx;
}

/* ==================== 段位系统和热力图样式 ==================== */

/* 顶部状态栏右侧区域 */
.status-bar .right-section {
  display: flex;
  align-items: flex-end;
  gap: 8rpx;
}

/* 段位徽章 */
.rank-badge {
  display: flex;
  align-items: center;
  padding: 8rpx 16rpx;
  border-radius: 20rpx;
  background-color: #cd7f32;
  color: #ffffff;
  font-size: 20rpx;
  font-weight: bold;
  box-shadow: 0 4rpx 8rpx rgba(0, 0, 0, 0.1);
}

.rank-icon {
  font-size: 22rpx;
  margin-right: 4rpx;
}

.rank-name {
  font-size: 20rpx;
}

/* 段位升级提示 */
.rank-tip {
  font-size: 20rpx;
  color: #999999;
  white-space: nowrap;
}

/* 连续打卡统计 */
.streak-stats {
  text-align: center;
  margin: 24rpx 32rpx;
  padding: 16rpx;
  background-color: #e6f7e6;
  border-radius: 16rpx;
  border: 2rpx solid #52c41a;
}

.current-streak {
  font-size: 32rpx;
  font-weight: bold;
  color: #52c41a;
}

.longest-streak {
  font-size: 24rpx;
  color: #666666;
  margin-left: 8rpx;
}

.streak-tip {
  display: block;
  font-size: 24rpx;
  color: #999999;
  margin-top: 8rpx;
  font-style: italic;
}

/* 热力图卡片 */
.heatmap-card {
  margin-top: 32rpx;
}

.heatmap-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.heatmap-header .label {
  font-size: 32rpx;
  font-weight: bold;
  color: #333333;
}

.month-navigation {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.prev-month, .next-month {
  font-size: 36rpx;
  color: #52c41a;
  font-weight: bold;
  width: 40rpx;
  height: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  cursor: pointer;
  transition: all 0.2s;
}

.prev-month:active, .next-month:active {
  background-color: #e6f7e6;
  transform: scale(0.9);
}

.current-month {
  font-size: 28rpx;
  font-weight: bold;
  color: #333333;
  min-width: 160rpx;
  text-align: center;
}

/* 星期标题 */
.weekdays {
  display: flex;
  justify-content: flex-start;
  margin-bottom: 8rpx;
}

.weekdays text {
  flex: 0 0 calc(100% / 7);
  text-align: center;
  font-size: 24rpx;
  padding: 8rpx 0;
  box-sizing: border-box;
}

.weekdays text:nth-child(1),
.weekdays text:nth-child(7) {
  color: #ff4757;
  font-weight: bold;
}

.weekdays text:nth-child(2),
.weekdays text:nth-child(3),
.weekdays text:nth-child(4),
.weekdays text:nth-child(5),
.weekdays text:nth-child(6) {
  color: #666666;
}

/* 日历网格 */
.calendar-grid {
  display: flex;
  flex-wrap: wrap;
  justify-content: flex-start;
}

.day-cell {
  flex: 0 0 calc(100% / 7);
  aspect-ratio: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  position: relative;
  border-radius: 8rpx;
  transition: all 0.2s;
  box-sizing: border-box;
}

.day-cell:active {
  transform: scale(0.95);
  opacity: 0.8;
}

.day-cell.other-month {
  opacity: 0.3;
}

.day-cell.today {
  border: 2rpx solid #52c41a;
  box-shadow: 0 0 8rpx rgba(82, 196, 26, 0.3);
}

.day-cell.weekend .day-number {
  color: #ff6b6b;
  font-weight: bold;
}

.day-cell.sunday .day-number {
  color: #ff4757;
  font-weight: bold;
}

.day-number {
  font-size: 24rpx;
  color: #333333;
  font-weight: normal;
}

.day-cell.other-month .day-number {
  color: #999999;
}

.punch-indicator {
  position: absolute;
  bottom: 8rpx;
  font-size: 20rpx;
  color: #ffffff;
  font-weight: bold;
  text-shadow: 0 1rpx 2rpx rgba(0, 0, 0, 0.3);
}

/* 图例 */
.heatmap-legend {
  display: flex;
  justify-content: center;
  gap: 32rpx;
  margin-top: 24rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid #eeeeee;
}

.legend-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.legend-color {
  width: 24rpx;
  height: 24rpx;
  border-radius: 4rpx;
}

.legend-text {
  font-size: 20rpx;
  color: #666666;
}

/* ==================== 用户数据统计面板样式 ==================== */
.stats-card {
  margin-top: 32rpx;
}

.stats-card .label {
  font-size: 32rpx;
  font-weight: bold;
  color: #333333;
}

.stats-tip {
  font-size: 24rpx;
  color: #52c41a;
  background-color: #e6f7e6;
  padding: 8rpx 16rpx;
  border-radius: 20rpx;
}

/* 关键指标网格 */
.stats-grid {
  display: flex;
  justify-content: space-between;
  margin: 24rpx 0;
}

.stat-item {
  flex: 1;
  text-align: center;
  padding: 16rpx 8rpx;
}

.stat-value {
  display: block;
  font-size: 48rpx;
  font-weight: bold;
  color: #52c41a;
  line-height: 1.2;
}

.stat-label {
  display: block;
  font-size: 22rpx;
  color: #666666;
  margin-top: 8rpx;
}

/* 统计区块 */
.stat-section {
  margin-top: 24rpx;
  padding-top: 24rpx;
  border-top: 1rpx solid #eeeeee;
}

.section-title {
  display: block;
  font-size: 28rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 16rpx;
}

/* 训练频率 */
.frequency-stats {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.frequency-item {
  font-size: 26rpx;
  color: #666666;
}

/* 部位训练次数 */
.part-stats {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.part-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.part-name {
  font-size: 26rpx;
  color: #333333;
  width: 40rpx;
  text-align: center;
}

.part-bar-container {
  flex: 1;
  height: 24rpx;
  background-color: #e6f7e6;
  border-radius: 12rpx;
  overflow: hidden;
}

.part-bar {
  height: 100%;
  background-color: #52c41a;
  border-radius: 12rpx;
  transition: width 0.3s ease;
}

.part-count {
  font-size: 22rpx;
  color: #666666;
  width: 80rpx;
  text-align: right;
}

/* 计划执行统计 */
.plan-stats {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.plan-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 12rpx 16rpx;
  background-color: #f6f6f6;
  border-radius: 12rpx;
}

.plan-name {
  font-size: 26rpx;
  color: #333333;
}

.plan-count {
  font-size: 26rpx;
  color: #52c41a;
  font-weight: bold;
}

/* ==================== 成就系统预览样式 ==================== */
.achievement-card {
  margin-top: 32rpx;
  transition: all 0.2s;
}

.achievement-card:active {
  opacity: 0.85;
  transform: scale(0.99);
}

.achievement-header-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.achievement-title {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.achievement-title .achievement-icon {
  font-size: 36rpx;
}

.achievement-card .label {
  font-size: 32rpx;
  font-weight: bold;
  color: #333333;
}

.achievement-badge {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 8rpx 20rpx;
  background-color: #f5f5f5;
  border-radius: 24rpx;
}

.badge-text {
  font-size: 26rpx;
  font-weight: 600;
  color: #666666;
}

.badge-arrow {
  font-size: 32rpx;
  color: #999999;
  font-weight: bold;
}

.achievement-progress-bar {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.progress-track {
  flex: 1;
  height: 8rpx;
  background-color: #f0f0f0;
  border-radius: 4rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #faad14, #ffc53d);
  border-radius: 4rpx;
  transition: width 0.3s ease;
}

.progress-label {
  font-size: 24rpx;
  font-weight: 600;
  color: #faad14;
  min-width: 64rpx;
  text-align: right;
}

/* ==================== 成就系统浮窗样式 ==================== */
.achievement-modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 999;
}

.achievement-modal {
  width: 90%;
  max-width: 640rpx;
  height: 70vh;
  background-color: #ffffff;
  border-radius: 24rpx;
  display: flex;
  flex-direction: column;
  overflow: hidden;
  box-shadow: 0 24rpx 80rpx rgba(0, 0, 0, 0.25);
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 28rpx 32rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.modal-title-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.modal-icon {
  font-size: 40rpx;
}

.modal-title {
  font-size: 34rpx;
  font-weight: bold;
  color: #333333;
}

.modal-close-btn {
  font-size: 44rpx;
  color: #999999;
  width: 56rpx;
  height: 56rpx;
  text-align: center;
  line-height: 56rpx;
  border-radius: 50%;
  transition: all 0.2s;
}

.modal-close-btn:active {
  background-color: #f5f5f5;
  color: #666666;
}

.modal-stats {
  padding: 24rpx 32rpx;
  background-color: #fafafa;
  border-bottom: 1rpx solid #f0f0f0;
}

.stats-text {
  display: block;
  font-size: 26rpx;
  color: #666666;
  margin-bottom: 16rpx;
  text-align: center;
}

.modal-progress-bar {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.modal-progress-track {
  flex: 1;
  height: 10rpx;
  background-color: #e8e8e8;
  border-radius: 5rpx;
  overflow: hidden;
}

.modal-progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #faad14, #ffc53d);
  border-radius: 5rpx;
  transition: width 0.3s ease;
}

.modal-progress-label {
  font-size: 24rpx;
  font-weight: bold;
  color: #faad14;
  min-width: 64rpx;
  text-align: right;
}

.achievement-list-scroll {
  flex: 1;
  height: 300rpx;
  padding: 24rpx;
  box-sizing: border-box;
  width: 100%;
  overflow-y: auto;
  -webkit-overflow-scrolling: touch;
}

.achievement-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.achievement-item {
  display: flex;
  align-items: flex-start;
  gap: 20rpx;
  padding: 20rpx;
  border-radius: 14rpx;
  background-color: #fafafa;
  border: 2rpx solid #f0f0f0;
  transition: all 0.2s;
}

.achievement-item.unlocked {
  background-color: #fffbe6;
  border-color: #faad14;
}

.achievement-item.locked {
  opacity: 0.6;
}

.achievement-item:active {
  transform: scale(0.99);
}

.item-left {
  position: relative;
  flex-shrink: 0;
}

.item-icon {
  font-size: 44rpx;
  display: block;
}

.item-status {
  position: absolute;
  bottom: -4rpx;
  right: -4rpx;
  font-size: 18rpx;
  width: 28rpx;
  height: 28rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.item-status.status-unlocked {
  background-color: #52c41a;
  color: #ffffff;
}

.item-status.status-locked {
  background-color: #d9d9d9;
  color: #ffffff;
}

.item-content {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.item-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #333333;
}

.item-condition {
  font-size: 22rpx;
  color: #888888;
}

/* ==================== 自主计划部位选择器样式 ==================== */
.part-selector-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.part-selector {
  width: 90%;
  max-width: 600rpx;
  background-color: #ffffff;
  border-radius: 24rpx;
  display: flex;
  flex-direction: column;
  overflow: hidden;
  box-shadow: 0 20rpx 60rpx rgba(0, 0, 0, 0.3);
  box-sizing: border-box;
}

/* 标题栏 */
.selector-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx;
  border-bottom: 1rpx solid #eeeeee;
  background-color: #e6f7e6;
}

.selector-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #52c41a;
}

.selector-close {
  font-size: 48rpx;
  color: #999999;
  width: 60rpx;
  height: 60rpx;
  text-align: center;
  line-height: 60rpx;
  border-radius: 50%;
  transition: all 0.2s;
}

.selector-close:active {
  background-color: #eeeeee;
  color: #666666;
}

/* 部位列表 */
.parts-list {
  flex: 1;
  max-height: 500rpx;
  padding: 0rpx 32rpx 24rpx;
  box-sizing: border-box;
  width: 100%;
}

/* 快速操作 */
.quick-actions {
  padding: 24rpx 0 16rpx;
  border-bottom: 1rpx solid #eeeeee;
  margin: 0 32rpx;
}

.repeat-last {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 20rpx 24rpx;
  background-color: #f0f9ff;
  border: 2rpx solid #1890ff;
  border-radius: 16rpx;
  transition: all 0.2s;
}

.repeat-last:active {
  background-color: #e6f7ff;
  transform: scale(0.98);
}

.repeat-icon {
  font-size: 28rpx;
  color: #1890ff;
  font-weight: bold;
}

.repeat-text {
  font-size: 26rpx;
  color: #1890ff;
  font-weight: 600;
}

/* 部位网格 */
.parts-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  padding-top: 24rpx;
  justify-content: center; /* 添加此行使网格项目整体居中 */
}

.part-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  /* 移除gap: 12rpx，因为现在只有一个元素 */
  padding: 40rpx 16rpx; /* 增加垂直padding，使文字在盒子中更居中 */
  border-radius: 16rpx;
  border: 2rpx solid #eeeeee;
  background-color: #fafafa;
  transition: all 0.2s;
  box-sizing: border-box;
  width: calc(50% - 8rpx);
  overflow: hidden;
  min-height: 120rpx; /* 添加最小高度，确保视觉平衡 */
}

.part-item:active {
  background-color: #f0f0f0;
  transform: scale(0.98);
}

.part-item.selected {
  border-color: #52c41a;
  background-color: #e6f7e6;
  transform: scale(1.02); /* 添加轻微放大效果 */
  box-shadow: 0 4rpx 12rpx rgba(82, 196, 26, 0.2);
}


.part-name {
  font-size: 28rpx; /* 从26rpx增加到28rpx */
  font-weight: bold;
  color: #333333;
  word-wrap: break-word;
  word-break: break-word;
  text-align: center;
  line-height: 1.2;
  /* 添加flex属性确保在flex容器中正确居中 */
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
}

.check-icon {
  font-size: 24rpx;
  font-weight: bold;
  color: #52c41a;
  width: 40rpx;
  height: 40rpx;
  text-align: center;
  line-height: 40rpx;
  border-radius: 50%;
  background-color: #ffffff;
  border: 2rpx solid #52c41a;
  flex-shrink: 0;
}

/* 确认按钮 */
.selector-footer {
  padding: 24rpx 32rpx;
  border-top: 1rpx solid #eeeeee;
  text-align: center;
  background-color: #e6f7e6;
}

.btn-confirm {
  background: linear-gradient(135deg, #87d068, #52c41a);
  color: #ffffff;
  font-size: 32rpx;
  font-weight: bold;
  padding: 24rpx 48rpx;
  border-radius: 80rpx;
  box-shadow: 0 8rpx 24rpx rgba(82, 196, 26, 0.3);
  border: none;
  width: 100%;
  max-width: 500rpx;
}

.btn-confirm[disabled] {
  background: #cccccc;
  box-shadow: none;
  opacity: 0.7;
}

.btn-confirm:active:not([disabled]) {
  transform: scale(0.96);
  box-shadow: 0 4rpx 12rpx rgba(82, 196, 26, 0.4);
}

