/* pages/index/index.wxss - 首页样式 */

.container {
  padding-bottom: 120rpx;
}

/* 顶部状态栏 */
.status-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx 32rpx 16rpx;
  background-color: #ffffff;
}

.date {
  font-size: 28rpx;
  color: #666666;
}

.plan-name {
  font-size: 24rpx;
  color: #52c41a;
  background-color: #e6f7e6;
  padding: 8rpx 16rpx;
  border-radius: 20rpx;
}

/* 训练卡片 */
.training-card {
  text-align: center;
  margin-top: 0;
}

.training-card .label {
  font-size: 28rpx;
  color: #666666;
  display: block;
  margin-bottom: 16rpx;
}

.training-card .today-part {
  font-size: 80rpx;
  font-weight: bold;
  color: #52c41a;
  display: block;
  margin: 24rpx 0;
  line-height: 1.2;
}

.training-card .tip {
  font-size: 24rpx;
  color: #999999;
  display: block;
}

/* 打卡按钮区域 */
.punch-section {
  text-align: center;
  margin: 48rpx 32rpx;
}

.btn-punch {
  background: linear-gradient(135deg, #87d068, #52c41a);
  color: #ffffff;
  font-size: 40rpx;
  font-weight: bold;
  padding: 32rpx 64rpx;
  border-radius: 80rpx;
  box-shadow: 0 8rpx 24rpx rgba(82, 196, 26, 0.3);
  border: none;
  width: 80%;
  max-width: 600rpx;
}

.btn-punch.punch-disabled {
  background: #cccccc;
  box-shadow: none;
  opacity: 0.7;
}

.punch-tip {
  display: block;
  font-size: 24rpx;
  color: #999999;
  margin-top: 16rpx;
}

/* 明日训练卡片 */
.tomorrow-card {
  text-align: center;
  margin-top: 24rpx;
}

.tomorrow-card .label {
  font-size: 28rpx;
  color: #666666;
  display: block;
  margin-bottom: 16rpx;
}

.tomorrow-card .tomorrow-part {
  font-size: 60rpx;
  font-weight: bold;
  color: #1890ff;
  display: block;
  margin: 16rpx 0;
}

.tomorrow-card .tip {
  font-size: 24rpx;
  color: #999999;
  display: block;
}

/* 计划卡片 */
.plan-card {
  margin-top: 32rpx;
}

.plan-card .label {
  font-size: 32rpx;
  font-weight: bold;
  color: #333333;
}

.change-plan {
  font-size: 26rpx;
  color: #52c41a;
  background-color: #e6f7e6;
  padding: 14rpx 28rpx;
  border-radius: 32rpx;
  border: 2rpx solid #52c41a;
  text-decoration: none;
  font-weight: 600;
  display: inline-block;
  transition: all 0.2s;
  box-shadow: 0 4rpx 12rpx rgba(82, 196, 26, 0.15);
}

.change-plan:active {
  background-color: #52c41a;
  color: #ffffff;
  transform: scale(0.96);
  box-shadow: 0 2rpx 8rpx rgba(82, 196, 26, 0.25);
}

.plan-desc {
  display: block;
  font-size: 28rpx;
  color: #666666;
  margin: 16rpx 0 24rpx;
}

.progress {
  margin-top: 24rpx;
}

.progress-text {
  font-size: 24rpx;
  color: #666666;
  display: block;
  margin-bottom: 12rpx;
}

.progress-percent {
  display: block;
  text-align: right;
  font-size: 24rpx;
  color: #52c41a;
  margin-top: 8rpx;
}

/* 睡眠卡片 */
.sleep-card {
  margin-top: 32rpx;
  padding: 24rpx;
}

.sleep-link {
  display: block;
  text-decoration: none;
  cursor: pointer;
  transition: all 0.2s;
}

.sleep-link:active {
  opacity: 0.8;
  transform: scale(0.99);
}

.sleep-card .label {
  font-size: 32rpx;
  font-weight: bold;
  color: #1890ff;
  display: block;
}

.sleep-tip {
  display: block;
  font-size: 24rpx;
  color: #999999;
  margin-top: 8rpx;
}

.sleep-card .icon {
  font-size: 36rpx;
  color: #1890ff;
  font-weight: bold;
}

/* 组队卡片 */
.team-card {
  margin-top: 32rpx;
  padding: 24rpx;
}

.team-link {
  display: block;
  text-decoration: none;
  cursor: pointer;
  transition: all 0.2s;
}

.team-link:active {
  opacity: 0.8;
  transform: scale(0.99);
}

.team-card .label {
  font-size: 32rpx;
  font-weight: bold;
  color: #722ed1;
  display: block;
}

.team-tip {
  display: block;
  font-size: 24rpx;
  color: #999999;
  margin-top: 8rpx;
}

.team-card .icon {
  font-size: 36rpx;
  color: #722ed1;
  font-weight: bold;
}

/* 底部提示 */
.footer-tip {
  text-align: center;
  font-size: 24rpx;
  color: #999999;
  margin-top: 48rpx;
  padding: 0 32rpx;
}