/* app.wxss - 全局样式 */

/* 全局字体和背景 */
page {
  background-color: #ffffff; /* 主色调：纯白背景 */
  font-family: -apple-system, BlinkMacSystemFont, 'Helvetica Neue', Helvetica, Segoe UI, Arial, Roboto, 'PingFang SC', 'miui', 'Hiragino Sans GB', 'Microsoft Yahei', sans-serif;
  color: #333333; /* 主文字颜色：深灰 */
  line-height: 1.6;
}

/* 卡片式设计 */
.card {
  background-color: #ffffff;
  border-radius: 16rpx;
  box-shadow: 0 4rpx 24rpx rgba(0, 0, 0, 0.04); /* 轻微阴影 */
  padding: 32rpx;
  margin: 32rpx;
}

/* 标题样式 */
.title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 24rpx;
}

.subtitle {
  font-size: 28rpx;
  color: #666666; /* 辅助文字颜色：浅灰 */
  margin-bottom: 16rpx;
}

/* 按钮基础样式 */
.btn {
  border-radius: 48rpx;
  padding: 24rpx 48rpx;
  font-size: 32rpx;
  font-weight: 500;
  text-align: center;
  transition: all 0.3s;
  border: none;
  display: inline-block;
  margin: 16rpx;
}

.btn:active {
  opacity: 0.8;
  transform: scale(0.98);
}

/* 训练计划 / 打卡按钮配色 */
.btn-training {
  background-color: #e6f7e6; /* 浅绿背景 */
  color: #52c41a; /* 绿色文字 */
  border: 2rpx solid #52c41a; /* 绿色边框 */
}

.btn-training.active {
  background-color: #52c41a;
  color: #ffffff;
}

/* 睡眠记录模块配色 */
.btn-sleep {
  background-color: #e6f7ff; /* 浅蓝背景 */
  color: #1890ff; /* 蓝色文字 */
  border: 2rpx solid #1890ff; /* 蓝色边框 */
}

.btn-sleep.active {
  background-color: #1890ff;
  color: #ffffff;
}

/* 其他按钮配色 */
.btn-other {
  background-color: #fff1f0; /* 浅粉背景 */
  color: #ff4d4f; /* 红色文字 */
  border: 2rpx solid #ff4d4f; /* 红色边框 */
}

.btn-other.active {
  background-color: #ff4d4f;
  color: #ffffff;
}

/* 浅黄配色 */
.btn-warning {
  background-color: #fffbe6; /* 浅黄背景 */
  color: #faad14; /* 黄色文字 */
  border: 2rpx solid #faad14; /* 黄色边框 */
}

.btn-warning.active {
  background-color: #faad14;
  color: #ffffff;
}

/* 输入框和选择器样式 */
.input, .picker {
  border: 2rpx solid #e8e8e8;
  border-radius: 12rpx;
  padding: 24rpx;
  font-size: 28rpx;
  background-color: #ffffff;
  margin-bottom: 24rpx;
}

.input:focus, .picker:focus {
  border-color: #52c41a;
  outline: none;
}

/* 间距工具类 */
.mt-16 { margin-top: 16rpx; }
.mt-24 { margin-top: 24rpx; }
.mt-32 { margin-top: 32rpx; }
.mb-16 { margin-bottom: 16rpx; }
.mb-24 { margin-bottom: 24rpx; }
.mb-32 { margin-bottom: 32rpx; }
.ml-16 { margin-left: 16rpx; }
.mr-16 { margin-right: 16rpx; }
.p-24 { padding: 24rpx; }
.p-32 { padding: 32rpx; }

/* 文本对齐 */
.text-center { text-align: center; }
.text-left { text-align: left; }
.text-right { text-align: right; }

/* 字体大小 */
.fs-24 { font-size: 24rpx; }
.fs-28 { font-size: 28rpx; }
.fs-32 { font-size: 32rpx; }
.fs-36 { font-size: 36rpx; }
.fs-48 { font-size: 48rpx; }
.fs-64 { font-size: 64rpx; }

/* 字体颜色 */
.color-primary { color: #333333; }
.color-secondary { color: #666666; }
.color-green { color: #52c41a; }
.color-blue { color: #1890ff; }
.color-red { color: #ff4d4f; }
.color-yellow { color: #faad14; }

/* 弹性布局 */
.flex {
  display: flex;
}

.flex-center {
  display: flex;
  align-items: center;
  justify-content: center;
}

.flex-between {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.flex-around {
  display: flex;
  align-items: center;
  justify-content: space-around;
}

.flex-column {
  display: flex;
  flex-direction: column;
}